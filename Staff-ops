<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Staff Operations AI — Module 02 | LUXE OPS</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --gold:#C9A84C;--gold-l:#E8C870;--gold-d:#8B6914;--gold-p:#F7F0DC;
  --dark:#07060A;--dark-2:#0F0D14;--dark-3:#1A1622;--dark-4:#252030;
  --mid:#3D3650;--muted:#8A7FA0;--light:#F2EEF8;--white:#FFFFFF;
  --border:rgba(201,168,76,0.15);--border-h:rgba(201,168,76,0.35);
  --green:#4CAF50;--red:#E53935;--amber:#F59E0B;--blue:#3B82F6;
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--dark);color:var(--white);overflow-x:hidden}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 2rem;height:64px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid transparent;transition:all .3s}
nav.scrolled{background:rgba(7,6,10,.92);border-bottom-color:var(–border);backdrop-filter:blur(12px)}
.nav-logo{font-family:‘Cormorant Garamond’,serif;font-size:1.35rem;font-weight:600;color:var(–gold-l);letter-spacing:3px;text-decoration:none}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{font-size:12px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.55);text-decoration:none;transition:color .2s}
.nav-links a:hover{color:var(–gold-l)}
.nav-badge{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(–muted);border:1px solid var(–border);padding:5px 12px;border-radius:3px}
.nav-cta{background:var(–gold);color:var(–dark);font-size:11px;letter-spacing:1.5px;text-transform:uppercase;padding:9px 20px;border-radius:3px;text-decoration:none;font-weight:500;transition:background .2s}
.nav-cta:hover{background:var(–gold-l)}

/* ── HERO ── */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:0 1.5rem;position:relative;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 40%,rgba(201,168,76,.07) 0%,transparent 70%)}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(201,168,76,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(201,168,76,.04) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 0%,transparent 100%)}
.hero-eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(201,168,76,.08);border:1px solid var(–border);border-radius:100px;padding:6px 18px;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(–gold);margin-bottom:2rem;position:relative}
.hero-dot{width:6px;height:6px;border-radius:50%;background:var(–green);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.8)}}
.hero h1{font-family:‘Cormorant Garamond’,serif;font-size:clamp(3rem,8vw,6.5rem);font-weight:300;line-height:1.05;color:var(–white);margin-bottom:1.5rem;position:relative}
.hero h1 em{font-style:italic;color:var(–gold-l)}
.hero-sub{font-size:clamp(1rem,2vw,1.2rem);color:rgba(255,255,255,.45);max-width:580px;line-height:1.7;margin-bottom:2.5rem;font-weight:300;position:relative}
.hero-actions{display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;position:relative}
.btn-primary{background:var(–gold);color:var(–dark);font-size:12px;letter-spacing:1.5px;text-transform:uppercase;padding:14px 32px;border-radius:3px;text-decoration:none;font-weight:500;transition:all .2s;border:none;cursor:pointer;font-family:‘DM Sans’,sans-serif}
.btn-primary:hover{background:var(–gold-l);transform:translateY(-1px)}
.btn-ghost{border:1px solid var(–border-h);color:var(–gold-l);font-size:12px;letter-spacing:1.5px;text-transform:uppercase;padding:14px 32px;border-radius:3px;text-decoration:none;transition:all .2s;display:inline-flex;align-items:center;gap:8px}
.btn-ghost:hover{background:rgba(201,168,76,.08)}
.hero-stats{display:flex;gap:3rem;margin-top:5rem;position:relative;flex-wrap:wrap;justify-content:center;padding-top:3rem;border-top:1px solid var(–border)}
.hero-stat .num{font-family:‘Cormorant Garamond’,serif;font-size:2.8rem;font-weight:300;color:var(–gold-l)}
.hero-stat .lbl{font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(–muted);margin-top:4px}

/* ── SHARED ── */
section{padding:6rem 1.5rem}
.container{max-width:1100px;margin:0 auto}
.section-label{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(–gold);margin-bottom:.6rem;font-weight:500}
.section-title{font-family:‘Cormorant Garamond’,serif;font-size:clamp(2rem,4vw,3rem);font-weight:300;line-height:1.2;color:var(–white)}
.section-title em{font-style:italic;color:var(–gold-l)}
.section-sub{font-size:15px;color:rgba(255,255,255,.45);margin-top:.6rem;line-height:1.7;max-width:540px;font-weight:300}
.fade-up{opacity:0;transform:translateY(30px);transition:opacity .6s ease,transform .6s ease}
.fade-up.visible{opacity:1;transform:none}

/* ── PROBLEM ── */
.problem{background:var(–dark-2)}
.problem-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1px;margin-top:3rem;border:1px solid var(–border)}
.problem-card{padding:2rem 1.5rem;background:var(–dark-2);transition:background .2s}
.problem-card:hover{background:var(–dark-3)}
.p-icon{font-size:1.8rem;margin-bottom:1rem}
.p-title{font-size:15px;font-weight:500;color:var(–white);margin-bottom:.5rem}
.p-desc{font-size:13px;color:var(–muted);line-height:1.6}

/* ── FEATURES ── */
.features-layout{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start;margin-top:3rem}
@media(max-width:860px){.features-layout{grid-template-columns:1fr}}
.features-list{display:flex;flex-direction:column}
.feature-item{display:flex;align-items:flex-start;gap:1rem;padding:1.4rem 0;border-bottom:1px solid var(–border);cursor:pointer;transition:all .2s}
.feature-item:first-child{border-top:1px solid var(–border)}
.feature-dot{width:8px;height:8px;border-radius:50%;background:var(–dark-4);border:1px solid var(–border-h);margin-top:5px;flex-shrink:0;transition:all .2s}
.feature-item.active .feature-dot,.feature-item:hover .feature-dot{background:var(–gold);box-shadow:0 0 8px rgba(201,168,76,.4)}
.feature-item.active .f-title{color:var(–gold-l)}
.f-title{font-size:15px;font-weight:500;color:rgba(255,255,255,.7);margin-bottom:.3rem;transition:color .2s}
.f-desc{font-size:13px;color:var(–muted);line-height:1.6}
.feature-preview{background:var(–dark-2);border:1px solid var(–border);border-radius:8px;padding:2rem;position:sticky;top:88px}
.fp-icon{font-size:2.5rem;margin-bottom:1rem}
.fp-title{font-family:‘Cormorant Garamond’,serif;font-size:1.6rem;font-weight:300;color:var(–white);margin-bottom:.6rem}
.fp-desc{font-size:13px;color:var(–muted);line-height:1.7;margin-bottom:1.5rem}
.fp-viz{background:var(–dark-3);border:1px solid var(–border);border-radius:6px;padding:1.2rem}
.fp-viz-label{font-family:‘DM Mono’,monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(–gold);margin-bottom:.8rem}
.fp-viz-row{font-family:‘DM Mono’,monospace;font-size:12px;color:var(–muted);line-height:2}

/* ── DEMO ── */
.demo-section{background:var(–dark-2);padding:5rem 1.5rem}
.demo-topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem}
.demo-container{max-width:1100px;margin:0 auto;background:var(–dark);border:1px solid var(–border);border-radius:8px;overflow:hidden;box-shadow:0 40px 100px rgba(0,0,0,.5)}
.db-bar{display:flex;align-items:center;justify-content:space-between;padding:0 1.5rem;height:50px;background:var(–dark-2);border-bottom:1px solid var(–border)}
.db-logo{font-family:‘DM Mono’,monospace;font-size:11px;letter-spacing:2px;color:var(–gold);text-transform:uppercase}
.db-nav{display:flex;gap:2px}
.db-btn{font-family:‘DM Mono’,monospace;font-size:10px;letter-spacing:1px;color:var(–muted);background:none;border:none;padding:6px 14px;cursor:pointer;border-radius:3px;transition:all .2s;text-transform:uppercase}
.db-btn:hover{color:var(–white);background:var(–dark-3)}
.db-btn.active{color:var(–gold);background:rgba(201,168,76,.08)}
.db-user{display:flex;align-items:center;gap:8px;font-size:12px;color:var(–muted)}
.db-av{width:28px;height:28px;border-radius:50%;background:var(–gold);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:var(–dark)}
.db-body{display:grid;grid-template-columns:200px 1fr;min-height:580px}
@media(max-width:768px){.db-body{grid-template-columns:1fr}}
.db-sidebar{background:var(–dark-2);border-right:1px solid var(–border);padding:1rem 0}
@media(max-width:768px){.db-sidebar{display:none}}
.db-slabel{font-family:‘DM Mono’,monospace;font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(–muted);padding:.8rem 1rem .4rem;display:block}
.db-sitem{display:flex;align-items:center;gap:8px;padding:8px 1rem;font-size:13px;color:var(–muted);cursor:pointer;transition:all .15s;border:1px solid transparent;margin:1px 8px;border-radius:4px}
.db-sitem:hover{background:var(–dark-3);color:var(–white)}
.db-sitem.active{background:rgba(201,168,76,.08);color:var(–gold);border-color:var(–border)}
.db-sicon{font-size:13px;width:16px;text-align:center}
.db-sbadge{margin-left:auto;background:var(–red);color:#fff;font-size:9px;font-family:‘DM Mono’,monospace;padding:1px 5px;border-radius:8px}
.db-sbadge.gold{background:rgba(201,168,76,.2);color:var(–gold)}
.db-content{padding:1.5rem;overflow-y:auto}

/* ── DASHBOARD VIEWS ── */
.db-view{display:none}
.db-view.active{display:block}
.db-ptitle{font-family:‘Cormorant Garamond’,serif;font-size:1.6rem;font-weight:300;color:var(–white);margin-bottom:.2rem}
.db-psub{font-family:‘DM Mono’,monospace;font-size:11px;color:var(–muted);margin-bottom:1.5rem;letter-spacing:.5px}

/* KPI */
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:1.5rem}
@media(max-width:860px){.kpi-row{grid-template-columns:repeat(2,1fr)}}
.kpi{background:var(–dark-2);border:1px solid var(–border);border-radius:6px;padding:1.1rem 1.2rem;position:relative;overflow:hidden}
.kpi::after{content:’’;position:absolute;bottom:0;left:0;right:0;height:2px}
.kpi.g::after{background:var(–green)}.kpi.r::after{background:var(–red)}.kpi.o::after{background:var(–gold)}.kpi.b::after{background:var(–blue)}
.kpi-lbl{font-family:‘DM Mono’,monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(–muted);margin-bottom:.6rem}
.kpi-val{font-family:‘Cormorant Garamond’,serif;font-size:2.2rem;font-weight:300;line-height:1;margin-bottom:.4rem}
.kpi-delta{font-size:11px;font-family:‘DM Mono’,monospace;color:var(–green)}
.kpi-delta.dn{color:var(–red)}

/* TABLE */
.tcard{background:var(–dark-2);border:1px solid var(–border);border-radius:6px;overflow:hidden;margin-bottom:1.2rem}
.thead{display:flex;align-items:center;justify-content:space-between;padding:.9rem 1.2rem;border-bottom:1px solid var(–border)}
.ttitle{font-family:‘DM Mono’,monospace;font-size:11px;letter-spacing:1px;color:var(–white);text-transform:uppercase}
.tact{font-family:‘DM Mono’,monospace;font-size:10px;letter-spacing:1px;color:var(–gold);background:none;border:1px solid var(–border-h);padding:4px 12px;border-radius:3px;cursor:pointer;transition:all .2s;text-transform:uppercase}
.tact:hover{background:rgba(201,168,76,.1)}
table{width:100%;border-collapse:collapse}
th{font-family:‘DM Mono’,monospace;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(–muted);text-align:left;padding:8px 1.2rem;background:var(–dark);border-bottom:1px solid var(–border);font-weight:400}
td{padding:12px 1.2rem;font-size:13px;color:rgba(255,255,255,.6);border-bottom:1px solid rgba(201,168,76,.05);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(255,255,255,.015)}

/* BADGES */
.badge{display:inline-flex;align-items:center;gap:4px;font-family:‘DM Mono’,monospace;font-size:10px;letter-spacing:1px;padding:3px 9px;border-radius:3px;text-transform:uppercase}
.badge::before{content:’’;width:5px;height:5px;border-radius:50%}
.badge-active{background:rgba(76,175,80,.1);color:var(–green)}.badge-active::before{background:var(–green);animation:pulse 1.5s infinite}
.badge-pending{background:rgba(201,168,76,.1);color:var(–gold)}.badge-pending::before{background:var(–gold)}
.badge-done{background:rgba(138,127,160,.1);color:var(–muted)}.badge-done::before{background:var(–muted)}
.badge-urgent{background:rgba(229,57,53,.1);color:var(–red)}.badge-urgent::before{background:var(–red);animation:pulse 1s infinite}
.pri-h{color:var(–red);font-size:12px}.pri-m{color:var(–amber);font-size:12px}.pri-l{color:var(–muted);font-size:12px}

/* BRIEFING */
.briefing{background:var(–dark-2);border:1px solid var(–border-h);border-radius:6px;overflow:hidden;margin-bottom:1.2rem}
.briefing-head{display:flex;align-items:center;gap:10px;padding:1rem 1.2rem;background:rgba(201,168,76,.05);border-bottom:1px solid var(–border)}
.briefing-icon{width:32px;height:32px;border-radius:4px;background:var(–gold);display:flex;align-items:center;justify-content:center;font-size:14px;color:var(–dark);flex-shrink:0}
.briefing-body{padding:1.5rem}
.briefing-body p{font-size:13px;color:rgba(255,255,255,.6);line-height:1.8;margin-bottom:1rem}
.briefing-body p:last-child{margin-bottom:0}
.briefing-hl{background:rgba(201,168,76,.05);border-left:2px solid var(–gold);padding:.8rem 1rem;margin:1rem 0;font-size:13px;color:rgba(255,255,255,.6);line-height:1.7}

/* INCIDENT */
.incident{display:flex;align-items:flex-start;gap:12px;padding:1rem 1.2rem;border-bottom:1px solid var(–border);transition:background .15s;cursor:pointer}
.incident:hover{background:rgba(255,255,255,.015)}
.incident:last-child{border-bottom:none}
.inc-sev{width:4px;align-self:stretch;border-radius:2px;flex-shrink:0}
.sev-crit{background:var(–red)}.sev-high{background:var(–amber)}.sev-norm{background:var(–blue)}
.inc-info{flex:1}
.inc-title{font-size:13px;color:var(–white);margin-bottom:3px}
.inc-meta{font-family:‘DM Mono’,monospace;font-size:10px;color:var(–muted)}
.inc-time{font-family:‘DM Mono’,monospace;font-size:10px;color:var(–muted);white-space:nowrap}

/* TWO COL */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;margin-bottom:1.2rem}
@media(max-width:768px){.two-col{grid-template-columns:1fr}}

/* AI CHAT */
.chat-wrap{background:var(–dark-2);border:1px solid var(–border);border-radius:6px;overflow:hidden}
.chat-msgs{padding:1.2rem;min-height:260px;max-height:300px;overflow-y:auto;display:flex;flex-direction:column;gap:10px}
.chat-msg{display:flex;gap:8px;align-items:flex-start;animation:fadeUp .3s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.chat-msg.user{flex-direction:row-reverse}
.chat-av{width:26px;height:26px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;flex-shrink:0}
.chat-av.ai{background:rgba(201,168,76,.15);color:var(–gold);font-family:‘DM Mono’,monospace;font-size:9px}
.chat-av.human{background:var(–dark-3);color:var(–muted)}
.chat-bbl{max-width:76%;padding:9px 12px;border-radius:4px;font-size:13px;line-height:1.6}
.chat-bbl.ai{background:var(–dark-3);border:1px solid var(–border);color:rgba(255,255,255,.7)}
.chat-bbl.human{background:rgba(201,168,76,.1);border:1px solid rgba(201,168,76,.2);color:var(–white)}
.chat-irow{display:flex;gap:8px;padding:1rem 1.2rem;border-top:1px solid var(–border);background:var(–dark)}
.chat-input{flex:1;background:var(–dark-3);border:1px solid var(–border);border-radius:3px;padding:9px 12px;font-size:13px;color:var(–white);font-family:‘DM Sans’,sans-serif;outline:none;transition:border-color .2s}
.chat-input::placeholder{color:var(–muted)}
.chat-input:focus{border-color:var(–border-h)}
.chat-send{background:var(–gold);color:var(–dark);border:none;padding:9px 18px;font-family:‘DM Mono’,monospace;font-size:10px;letter-spacing:1px;text-transform:uppercase;cursor:pointer;border-radius:3px;transition:background .2s;font-weight:500}
.chat-send:hover{background:var(–gold-l)}
.chat-quick{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px}
.chat-qbtn{background:transparent;border:1px solid var(–border);border-radius:100px;padding:4px 12px;font-size:10px;color:var(–gold);cursor:pointer;font-family:‘DM Sans’,sans-serif;transition:background .15s;letter-spacing:.5px}
.chat-qbtn:hover{background:rgba(201,168,76,.08)}
.typing{display:none;gap:4px;align-items:center;padding:8px 12px}
.typing.show{display:flex}
.tdot{width:5px;height:5px;border-radius:50%;background:var(–gold);animation:typ 1.2s infinite}
.tdot:nth-child(2){animation-delay:.2s}.tdot:nth-child(3){animation-delay:.4s}
@keyframes typ{0%,100%{opacity:.3;transform:scale(.8)}50%{opacity:1;transform:scale(1)}}

/* MODAL */
.modal-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:500;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.modal-ov.open{display:flex}
.modal{background:var(–dark-2);border:1px solid var(–border-h);border-radius:8px;padding:2rem;max-width:480px;width:90%;position:relative}
.modal h3{font-family:‘Cormorant Garamond’,serif;font-size:1.8rem;font-weight:300;margin-bottom:.4rem}
.modal p{font-size:13px;color:var(–muted);line-height:1.7;margin-bottom:1.5rem}
.modal-x{position:absolute;top:1rem;right:1rem;background:none;border:none;color:var(–muted);font-size:18px;cursor:pointer;transition:color .2s;line-height:1}
.modal-x:hover{color:var(–white)}
.fg{margin-bottom:1rem}
.fg label{display:block;font-family:‘DM Mono’,monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(–muted);margin-bottom:.4rem}
.fg input,.fg select{width:100%;background:var(–dark-3);border:1px solid var(–border);border-radius:3px;padding:9px 12px;font-size:13px;color:var(–white);font-family:‘DM Sans’,sans-serif;outline:none;transition:border-color .2s;appearance:none}
.fg input:focus,.fg select:focus{border-color:var(–border-h)}
.fg select option{background:var(–dark-3)}
.fg-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}

/* ── HOW IT WORKS ── */
.how-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;margin-top:3rem;background:var(–border);border:1px solid var(–border)}
@media(max-width:700px){.how-grid{grid-template-columns:1fr}}
.how-step{background:var(–dark-2);padding:2.5rem 2rem;position:relative;overflow:hidden}
.step-bg{font-family:‘Cormorant Garamond’,serif;font-size:6rem;font-weight:300;color:rgba(201,168,76,.05);position:absolute;top:1rem;right:1.5rem;line-height:1}
.step-tag{font-family:‘DM Mono’,monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(–gold);margin-bottom:1.2rem;display:block}
.how-step h3{font-size:18px;font-weight:500;color:var(–white);margin-bottom:.8rem}
.how-step p{font-size:13px;color:var(–muted);line-height:1.7}

/* ── PRICING ── */
.pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
@media(max-width:860px){.pricing-grid{grid-template-columns:1fr;max-width:360px;margin:3rem auto 0}}
.price-card{background:var(–dark-3);border:1px solid var(–border);border-radius:8px;padding:2rem;position:relative;transition:transform .2s}
.price-card:hover{transform:translateY(-4px)}
.price-card.featured{border-color:var(–gold);background:linear-gradient(135deg,var(–dark-3),rgba(201,168,76,.06))}
.price-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(–gold);color:var(–dark);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;padding:4px 14px;border-radius:100px;font-weight:500;white-space:nowrap}
